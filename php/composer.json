{
    "name": "seadrip/creages-server",
    "description": "The Laravel Lumen Framework.",
    "keywords": ["seadrip", "creages", "server", "mxs"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.5",
        "ext-json": "*",
        "ext-mbstring": "*",
        "seadrip/common": "@dev",
        "seadrip/mxs": "*@dev"
    },
    "minimum-stability": "dev",
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../mxs/MeteorStreet",
            "options": {
                "symlink": true
            }
        }
    ]
}
